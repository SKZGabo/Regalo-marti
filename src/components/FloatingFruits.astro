<!-- Frutas flotantes -->
<div class="floating-fruits">
  <img src="/fotos/7.jpg" class="fruit f1" alt="Fruta del Diablo 1" />
  <img src="/fotos/8.jpg" class="fruit f2" alt="Fruta del Diablo 2" />
  <img src="/fotos/9png.png" class="fruit f3" alt="Fruta del Diablo 3" />
  <img src="/fotos/10.jpg" class="fruit f4" alt="Fruta del Diablo 4" />
  <img src="/fotos/11.png" class="fruit f5" alt="Fruta del Diablo 5" />
</div>

<style>
  /* Estilos para frutas flotantes */
  .floating-fruits {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
  }
  .fruit {
    position: absolute;
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid var(--gold);
    box-shadow: 0 0 25px rgba(255, 215, 0, 0.8), inset 0 0 15px rgba(0,0,0,0.7);
    opacity: 0.9;
  }
  .f1 { top: 15%; left: 2%; animation: levitate1 6s ease-in-out infinite; }
  .f2 { top: 50%; right: 2%; animation: levitate2 8s ease-in-out infinite; }
  .f3 { bottom: 25%; left: 3%; animation: levitate3 7s ease-in-out infinite; }
  .f4 { top: 70%; right: 3%; animation: levitate4 9s ease-in-out infinite; }
  .f5 { top: 20%; right: 5%; animation: levitate5 10s ease-in-out infinite; }

  @keyframes levitate1 {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-40px) rotate(5deg); }
  }
  @keyframes levitate2 {
    0%, 100% { transform: translateY(0) rotate(5deg); }
    50% { transform: translateY(35px) rotate(-5deg); }
  }
  @keyframes levitate3 {
    0%, 100% { transform: translateY(0) rotate(-3deg); }
    50% { transform: translateY(-30px) rotate(7deg); }
  }
  @keyframes levitate4 {
    0%, 100% { transform: translateY(0) rotate(4deg); }
    50% { transform: translateY(45px) rotate(-6deg); }
  }
  @keyframes levitate5 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-50px) rotate(4deg); }
  }
</style>
