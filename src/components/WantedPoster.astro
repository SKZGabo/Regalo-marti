---
const {
  name = "Marti",
  bounty = "440,000,000",
  photo = "/fotos/1.jpeg",
  epithet = "Reina del Cumpleaños",
} = Astro.props;
---

<div class="wanted-poster floating">
  <div class="wanted-photo">
    {
      photo ? (
        <img
          src={photo}
          alt={name}
          style="width: 100%; height: 100%; object-fit: cover;"
        />
      ) : (
        <span style="font-size: 4rem;">🏴‍☠️</span>
      )
    }
  </div>

  <div class="wanted-name">{name}</div>
  <div
    class="wanted-epithet"
    style="color: var(--treasure-brown); font-style: italic; margin-bottom: 0.5rem;"
  >
    "{epithet}"
  </div>
  <div class="wanted-bounty">
    <span>฿</span>
    {bounty}
  </div>

  <div
    style="margin-top: 1rem; padding-top: 1rem; border-top: 2px solid var(--wanted-red);"
  >
    <p style="font-size: 0.8rem; color: #666;">
      SE BUSCA VIVO O DEAD<br />
      Por: Ser demasiado increíble
    </p>
  </div>
</div>

<style>
  .wanted-poster {
    background: var(--parchment);
    border: 8px solid var(--wanted-yellow);
    box-shadow:
      var(--pirate-shadow),
      inset 0 0 30px rgba(139, 69, 19, 0.3);
    padding: 2rem;
    max-width: 400px;
    margin: 2rem auto;
    position: relative;
    text-align: center;
    transform: rotate(-2deg);
    transition: all 0.3s ease;
  }

  .wanted-poster::before {
    content: "WANTED";
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Trade Winds", cursive;
    font-size: 3rem;
    color: var(--wanted-red);
    text-shadow: 3px 3px 0 rgba(0, 0, 0, 0.3);
    z-index: 1;
    letter-spacing: 5px;
  }

  .wanted-poster:hover {
    transform: rotate(0deg) scale(1.05);
    box-shadow:
      10px 10px 0 rgba(0, 0, 0, 0.5),
      0 0 50px rgba(255, 215, 0, 0.3);
  }

  .wanted-photo {
    width: 200px;
    height: 200px;
    margin: 3rem auto 1rem;
    border: 5px solid var(--treasure-brown);
    border-radius: 10px;
    overflow: hidden;
    background: #ddd;
  }

  .wanted-name {
    font-family: "Pirata One", cursive;
    font-size: 2rem;
    color: var(--black);
    margin: 0.5rem 0;
  }

  .wanted-bounty {
    font-family: "MedievalSharp", cursive;
    font-size: 1.5rem;
    color: var(--wanted-red);
    margin: 0.5rem 0;
  }

  .wanted-bounty span {
    font-size: 2rem;
    font-weight: bold;
  }

  .floating {
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }
</style>
